                                        <div class="x_tva_form_group">
                                            <label for="tva_name">Nombre Completo</label>
                                            <input type="text" id="tva_name" name="name"
                                                   placeholder="Ej: Juan Pérez" required="required"/>
                                        </div>
                                        <div class="x_tva_form_group">
                                            <label for="tva_email">Email Corporativo / Personal</label>
                                            <input type="email" id="tva_email" name="email"
                                                   placeholder="email@ejemplo.com" required="required"/>
                                        </div>
                                        <div class="x_tva_form_group">
                                            <label for="tva_phone">Teléfono / WhatsApp</label>
                                            <input type="tel" id="tva_phone" name="phone"
