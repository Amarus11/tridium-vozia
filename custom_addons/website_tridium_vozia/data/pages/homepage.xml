                                        <div class="x_tva_form_group">
                                            <label for="tva_country">País de Residencia</label>
                                            <select id="tva_country" name="country" required="required">
                                                <option value="PA">Panamá</option>
                                                <option value="CO">Colombia</option>
                                                <option value="MX">México</option>
                                                <option value="BR">Brasil</option>
                                                <option value="US">Estados Unidos</option>
                                                <option value="OTHER">Otros</option>
                                            </select>
                                        </div>
                                        <div class="x_tva_form_group">
                                            <label for="tva_level">Nivel de Interés</label>
                                            <select id="tva_level" name="level">
                                                <option value="A1">A1 — Foundations ($180 USD)</option>
                                                <option value="A2">A2 — Elementary ($180 USD)</option>
                                                <option value="B1">B1 — Intermediate ($250 USD)</option>
                                                <option value="B2">B2 — Upper-Intermediate ($350 USD)</option>
                                                <option value="C1">C1 — Advanced ($450 USD)</option>
                                                <option value="C2">C2 — Mastery ($550 USD)</option>
                                            </select>
                                        </div>
